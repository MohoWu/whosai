# Keep provider-specific secrets out of source control.
# DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# LangSmith tracing is opt-in. Leave false for normal local tests.
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=whosai-dev
# LANGSMITH_API_KEY=
# Use the endpoint matching the LangSmith account region.
# LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
# Required for organization-scoped keys or keys that can access multiple workspaces.
# LANGSMITH_WORKSPACE_ID=

# Enable these before tracing any chat that may contain sensitive content.
LANGSMITH_HIDE_INPUTS=true
LANGSMITH_HIDE_OUTPUTS=true

# Keep disabled outside automated browser tests.
WHOSAI_E2E=0
